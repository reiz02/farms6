/* register.css */

/* ===== 1. PAGE WRAPPER ===== */
.login-page-wrapper {
  /* Ang background ay galing na sa App.css, kaya transparent na ito */
  background: transparent !important;
  min-height: 100vh;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px;
  position: relative;
  z-index: 2; /* Para nasa ibabaw ng App-overlay at background shapes */
}

/* ===== 2. MODERN WHITE CARD (Glassmorphism hint) ===== */
.register-container, .login-container {
  /* Ultra-pure white na may subtle transparency */
  background: rgba(255, 255, 255, 0.98) !important;
  width: 100%;
  max-width: 480px; /* Mas compact */
  padding: 35px 40px;
  border-radius: 28px; /* Mas rounded, mas modern */
  
  /* Softer and wider shadow for premium look */
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
  
  text-align: center;
  position: relative;
  
  /* Prevent cutting off elements while keeping it compact */
  max-height: 95vh;
  overflow-y: auto;
  
  /* Initial state para sa Entrance Animation */
  opacity: 0;
  transform: translateY(30px);
  animation: cardEntrance 0.6s ease-out forwards;
}

/* Custom Scrollbar para sa loob ng card (para sa maliit na screens) */
.register-container::-webkit-scrollbar {
  width: 5px;
}
.register-container::-webkit-scrollbar-thumb {
  background: #e2e8f0;
  border-radius: 10px;
}

/* ===== 3. LOGO & HEADERS ===== */
.login-header {
  margin-bottom: 25px;
}

.brand-logo {
  font-size: 34px;
  font-weight: 800;
  color: #438a5e;
  letter-spacing: -1.5px;
  margin: 0;
}

.brand-logo span { color: #2c3e50; }

.login-header h2 {
  font-size: 19px;
  font-weight: 700;
  color: #1f2937;
  margin-top: 5px;
}

.subtitle {
  font-size: 13px;
  color: #6b7280;
  margin-top: 3px;
}

/* ===== 4. FORM LAYOUT & COMPACT INPUTS ===== */
.input-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

.input-group {
  text-align: left;
  margin-bottom: 14px; /* Dikit-dikit para magkasya */
  width: 100%;
  
  /* Initial state para sa staggered input animation */
  opacity: 0;
  transform: translateY(15px);
  animation: fadeUpStaggered 0.5s ease-out forwards;
}

.input-group label {
  display: block;
  font-size: 12px;
  font-weight: 600;
  color: #4b5563;
  margin-bottom: 6px;
  margin-left: 3px;
}

/* ===== 5. INPUTS STYLE (Clean & Modern) ===== */
.input-group input,
.input-group select {
  width: 100%;
  height: 46px; /* Reduced from 50px */
  padding: 10px 16px;
  font-size: 14px;
  border: 1px solid #e5e7eb;
  background-color: #f9fafb;
  border-radius: 12px;
  color: #1f2937;
  transition: all 0.2s ease;
  appearance: none;
}

/* Modern focus state with FarmOps theme */
.input-group input:focus,
.input-group select:focus {
  outline: none;
  border-color: #438a5e;
  background-color: #ffffff;
  /* Mas modern na focus shadow */
  box-shadow: 0 0 0 4px rgba(67, 138, 94, 0.12);
}

/* Fix para sa Chrome Autofill */
input:-webkit-autofill {
  -webkit-box-shadow: 0 0 0px 1000px #f9fafb inset !important;
  border-radius: 12px;
}

/* ===== 6. PASSWORD EYE ICON ===== */
.password-field-container {
  position: relative;
}

.eye-icon-trigger {
  position: absolute;
  right: 14px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #9ca3af;
  cursor: pointer;
  transition: color 0.2s;
  padding: 5px;
}

.eye-icon-trigger:hover {
  color: #438a5e;
}

/* ===== 7. PREMIUM BUTTONS ===== */
.login-btn {
  width: 100%;
  padding: 14px;
  /* FarmOps Deep Green Gradient for premium look */
  background: linear-gradient(135deg, #234d37 0%, #1a3a2a 100%);
  color: #ffffff;
  border: none;
  border-radius: 12px;
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  margin-top: 10px;
  transition: all 0.3s ease;
  
  /* Initial state for staggered entry */
  opacity: 0;
  transform: translateY(15px);
  animation: fadeUpStaggered 0.5s ease-out forwards;
}

.login-btn:hover {
  background: linear-gradient(135deg, #1d412e 0%, #132a1f 100%);
  transform: translateY(-1px);
  box-shadow: 0 8px 20px rgba(26, 58, 42, 0.25);
}

.login-btn:active {
  transform: scale(0.99);
}

/* ===== 8. FOOTER LINKS ===== */
.footer-text, .footer-links {
  margin-top: 25px;
  font-size: 13px;
  color: #6b7280;
  
  /* Staggered entry animation */
  opacity: 0;
  transform: translateY(10px);
  animation: fadeUpStaggered 0.4s ease-out forwards;
}

.register-link {
  color: #438a5e;
  text-decoration: none;
  font-weight: 700;
  margin-left: 5px;
  transition: color 0.2s;
}

.register-link:hover {
  color: #2a5d43;
  text-decoration: underline;
}

/* ===== 9. OTP POPUP (Premium Modals) ===== */
.dialog-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(8px); /* Mas blur ang background */
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.dialog-box {
  background: #ffffff;
  padding: 40px;
  border-radius: 24px;
  width: 90%;
  max-width: 380px;
  text-align: center;
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.3);
  
  /* Popup entrance animation */
  opacity: 0;
  transform: scale(0.9) translateY(20px);
  animation: popupEntrance 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

.otp-input-field {
  width: 100%;
  height: 60px;
  font-size: 32px;
  letter-spacing: 10px;
  font-weight: 800;
  text-align: center;
  border: 2px solid #e2e8f0;
  border-radius: 12px;
  margin: 20px 0;
  background: #f8fafc;
}

.resend-btn {
  background: none;
  border: none;
  color: #438a5e;
  font-weight: 700;
  cursor: pointer;
  font-size: 13px;
  margin-top: 10px;
}

/* ===== 10. ADVANCED KEYFRAMES ANIMATIONS ===== */

/* Card entrance payuko */
@keyframes cardEntrance {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Staggered fade-up entry ( JS handles the delay) */
@keyframes fadeUpStaggered {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Popup entrance (may kaunting bounce) */
@keyframes popupEntrance {
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

/* Slide Up default animation */
@keyframes slideUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== 11. MOBILE RESPONSIVE QUERIES ===== */
@media (max-width: 500px) {
  .input-row {
    grid-template-columns: 1fr; /* Stack names on mobile */
    gap: 0;
  }
  .register-container {
    padding: 25px 20px;
    margin: 10px;
  }
}








